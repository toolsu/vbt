{
  "name": "vbt",
  "version": "1.3.0",
  "description": "Lightweight CLI to bump package version, replace version strings in marked files, and create git commits and tags",
  "keywords": [
    "version",
    "bump",
    "git",
    "tag",
    "semver",
    "cli",
    "release",
    "replace",
    "package-json"
  ],
  "homepage": "https://github.com/toolsu/vbt#readme",
  "bugs": {
    "url": "https://github.com/toolsu/vbt/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toolsu/vbt.git"
  },
  "license": "MIT",
  "author": "Tom Chen <tomchen.org@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vbt": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "npm run lint:check && npm run format:check && npm run typecheck",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint --write .",
    "lint:check": "biome lint .",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "semver-ts": "^1.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
