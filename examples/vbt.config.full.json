{
  "requireCleanWorkingDirectory": true,
  "preBumpCheck": "npm run lint && npm run typecheck && npm test && npm run build",
  "manifest": "./package.json",
  "files": ["src/version.ts", "README.md"],
  "marker": "vbt-version",
  "commitMessage": "chore: release v{{version}} [skip ci]",
  "commitFiles": ["CHANGELOG.md", "package-lock.json"],
  "tag": "v{{version}}",
  "tagMessage": "Release v{{version}}\n\nSee CHANGELOG.md for details.",
  "push": true,
  "postVerRepl": "npm run format",
  "postBumpHook": "npm run build && npm publish",
  "verbose": true,
  "dryRun": false
}
